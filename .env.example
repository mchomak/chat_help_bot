# === Bot ===
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8443
WEBHOOK_SECRET=your-random-secret-string

# === Database (async) ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/chat_help_bot
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

# === AI API ===
AI_API_KEY=sk-your-openai-api-key
AI_API_BASE_URL=https://api.openai.com/v1
AI_DEFAULT_MODEL=gpt-4o
AI_VISION_MODEL=gpt-4o
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.8
AI_REQUEST_TIMEOUT=60

# === Proxy (comma-separated list, leave empty to disable) ===
PROXY_LIST=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080
PROXY_CONNECT_TIMEOUT=10
PROXY_READ_TIMEOUT=30
PROXY_MAX_RETRIES=3
PROXY_COOLDOWN_SECONDS=120
PROXY_SLOW_THRESHOLD=20

# === Trial ===
TRIAL_DURATION_HOURS=2

# === General ===
DEBUG=false
LOG_LEVEL=INFO
TEMP_DIR=/tmp/chat_help_bot
