# ================================================================
# Copy this file to .env and fill in your values
# ================================================================

# === Bot ===
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Public HTTPS URL where Telegram delivers webhook updates.
# Must be https:// with a valid TLS cert.
# Example: https://yourdomain.com or https://1.2.3.4 (with self-signed + upload)
WEBHOOK_HOST=https://your-domain.com

# Path Telegram will POST to. Usually /webhook
WEBHOOK_PATH=/webhook

# Internal port the aiohttp server listens on INSIDE the container.
# Nginx/Caddy on the host proxies to this.
WEBHOOK_PORT=8080

# Random string used to verify that updates are from Telegram.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=your-random-secret-string

# Port exposed from the container to the host (docker-compose).
# Nginx on host should proxy to 127.0.0.1:<BOT_INTERNAL_PORT>
BOT_INTERNAL_PORT=8080

# === Database ===
# For local dev without Docker: change @db to @localhost
# For docker-compose: leave @db as is (service name)
DATABASE_URL=postgresql+asyncpg://botuser:strongpassword@db:5432/chat_help_bot
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

# === PostgreSQL (used by docker-compose to init the DB container) ===
POSTGRES_DB=chat_help_bot
POSTGRES_USER=botuser
POSTGRES_PASSWORD=strongpassword

# === AI API ===
AI_API_KEY=sk-your-openai-api-key
AI_API_BASE_URL=https://api.openai.com/v1
AI_DEFAULT_MODEL=gpt-4o
AI_VISION_MODEL=gpt-4o
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.8
AI_REQUEST_TIMEOUT=60

# Language for internal AI prompts: "en" (English) or "ru" (Russian).
# This only changes the language of prompts sent to the AI model — user interface stays in Russian.
# Use "ru" to test how the model performs with Russian-language instructions.
AI_PROMPT_LANGUAGE=en

# === Proxy (comma-separated, leave empty to disable) ===
PROXY_LIST=
PROXY_CONNECT_TIMEOUT=10
PROXY_READ_TIMEOUT=30
PROXY_MAX_RETRIES=3
PROXY_COOLDOWN_SECONDS=120
PROXY_SLOW_THRESHOLD=20

# === Trial ===
TRIAL_DURATION_HOURS=2

# === Limits ===
MONTHLY_IMAGE_LIMIT=300

# === Legal documents ===
# URLs shown as inline buttons in the consent message at first launch.
# Leave empty to show the consent text without document links.
USER_AGREEMENT_URL=
PRIVACY_POLICY_URL=

# === Referral system ===
# Bonus credited to the referrer when an invited user makes a payment.
REFERRAL_REWARD_DAYS=7
REFERRAL_REWARD_SCREENSHOTS=150

# === YooKassa ===
# Get shop_id and api_key from your YooKassa merchant dashboard.
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_API_KEY=your-secret-api-key
# URL users are redirected to after payment (use your bot's t.me link)
YOOKASSA_RETURN_URL=https://t.me/your_bot_username
# Path on this server that YooKassa POSTs payment status updates to
YOOKASSA_WEBHOOK_PATH=/yookassa/webhook

# Tariff prices and periods are defined statically in app/tariffs_config.py — not in .env.

# === General ===
DEBUG=false
LOG_LEVEL=INFO
TEMP_DIR=/tmp/chat_help_bot
